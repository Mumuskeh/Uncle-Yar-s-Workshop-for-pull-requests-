; SIG MCX LVAW
;a small, integrally suppresed subsonic MCX, so we look at the tweaks for RWAP's
;range should be a bit higher than SMGs with 300 BKT, but this is a 5.45 model so a bit lower than M4s
;Only rpm I can find is 927 on demo guns, with production models supposed to be a bit lower
;no reason for ap_modifier that I can see, unless this were the 300 BKT model
;would the 5.45 model be subsonic? can't find anything about it
![wpn_lvaw]
inv_weight		= 2.20 ; 2.04
hit_impulse		= 25 ; 30
hit_power		= 0.49, 0.49, 0.49, 0.49 ; 0.57, 0.57, 0.57, 0.57
fire_distance	= 410 ; 650
; bullet_speed	= 600 ; 259
rpm				= 877 ; 857

